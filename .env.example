APP_NAME="GSS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.guanshanshan.cn
APP_TIMEZONE=Asia/Shanghai
TRUSTED_PROXIES=*

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=php_demo
DB_USERNAME=phpuser
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_COOKIE=portal_sid
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=failover
# CACHE_PREFIX=
FRONTEND_PAGE_CACHE_ENABLED=true
FRONTEND_PAGE_CACHE_TTL=300

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# REDIS_URL=
# REDIS_CACHE_URL=
REDIS_HOST=127.0.0.1
# REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default
REDIS_TIMEOUT=1.0
REDIS_READ_TIMEOUT=1.0
REDIS_RETRY_INTERVAL=100
REDIS_MAX_RETRIES=1
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=500

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
